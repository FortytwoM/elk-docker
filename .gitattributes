# Shell scripts and entrypoints must use LF (Docker runs on Linux)
*.sh       text eol=lf
*.conf     text eol=lf
*.yml      text eol=lf
*.yaml     text eol=lf
Dockerfile text eol=lf
Makefile   text eol=lf

# Windows-only files
*.ps1      text eol=crlf
*.bat      text eol=crlf
*.cmd      text eol=crlf
