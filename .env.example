ELASTIC_VERSION=9.3.0

# External IP or hostname of the Docker host (for Fleet agent enrollment).
# Agents on other machines use this to reach Fleet Server and Elasticsearch.
# Leave empty for local-only deployment (default: Docker internal names).
#FLEET_EXTERNAL_HOST=192.168.1.100

# Passwords — change before first run
ELASTIC_PASSWORD='changeme'
LOGSTASH_INTERNAL_PASSWORD='changeme'
KIBANA_SYSTEM_PASSWORD='changeme'

# Beats users (leave empty if not using Beats extensions)
METRICBEAT_INTERNAL_PASSWORD=''
FILEBEAT_INTERNAL_PASSWORD=''
HEARTBEAT_INTERNAL_PASSWORD=''
MONITORING_INTERNAL_PASSWORD=''
BEATS_SYSTEM_PASSWORD=''
