ELASTIC_VERSION=9.3.0

# Base directory for Elasticsearch and Fleet Server data.
# Default: ./data (next to the project).
# External drive example: DATA_PATH=E:\docker-elk-data (Windows) or /mnt/disk/docker-elk (Linux)
DATA_PATH=./data

## Passwords for stack users
## Change these before first run!

# User 'elastic' (built-in superuser)
ELASTIC_PASSWORD='changeme'

# User 'logstash_internal' (Logstash → Elasticsearch)
LOGSTASH_INTERNAL_PASSWORD='changeme'

# User 'kibana_system' (Kibana → Elasticsearch)
KIBANA_SYSTEM_PASSWORD='changeme'

# Optional: Beats users (leave empty if not using Beats)
METRICBEAT_INTERNAL_PASSWORD=''
FILEBEAT_INTERNAL_PASSWORD=''
HEARTBEAT_INTERNAL_PASSWORD=''
MONITORING_INTERNAL_PASSWORD=''
BEATS_SYSTEM_PASSWORD=''
